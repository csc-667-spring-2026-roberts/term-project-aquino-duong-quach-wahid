{
  "name": "term-project",
  "version": "1.0.0",
  "description": "CSC 667 Term Project - Spring 2026",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:server && npm run build:client && npm run migrate:up",
    "build:server": "tsc",
    "build:client": "esbuild src/client/main.ts --bundle --outfile=public/js/main.js && esbuild src/client/lobby.ts --bundle --outfile=public/js/lobby.js",
    "watch:client": "esbuild src/client/main.ts --bundle --outfile=public/js/main.js --watch & esbuild src/client/lobby.ts --bundle --outfile=public/js/lobby.js --watch",
    "start": "node dist/server.js",
    "dev": "concurrently \"tsx watch src/server.ts\" \"npm run watch:client\"",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist/",
    "migrate:create": "node-pg-migrate -j ts create",
    "migrate:up": "node --import tsx/esm node_modules/node-pg-migrate/bin/node-pg-migrate.js up",
    "migrate:down": "node --import tsx/esm node_modules/node-pg-migrate/bin/node-pg-migrate.js down",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/dotenv": "^6.1.1",
    "@types/ejs": "^3.1.5",
    "@types/express-session": "^1.18.2",
    "@types/node": "^20.11.0",
    "@types/pg-promise": "^0.0.28",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "livereload": "^0.10.3",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "node-pg-migrate": "^8.0.4",
    "pg-promise": "^12.6.2"
  }
}
