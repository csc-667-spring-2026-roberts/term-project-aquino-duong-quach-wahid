<%- include("../partials/head", { title: "Login" }) %>
<%- include("../partials/header", {
  user: typeof user !== "undefined" ? user : null,
  error: typeof error !== "undefined" ? error : null
}) %>

<section class="auth-scene" aria-labelledby="login-title">
  <div class="auth-copy">
    <p class="eyebrow">Your turn</p>
    <h1 id="login-title">Jump Back In</h1>
    <p>Grab your hand, read the table, and make the next play count.</p>

    <div class="mini-card-row" aria-hidden="true">
      <span class="mini-uno-card mini-red">UNO</span>
      <span class="mini-uno-card mini-yellow">+2</span>
      <span class="mini-uno-card mini-blue">Skip</span>
    </div>
  </div>

  <section class="auth-panel" aria-label="Login form">
    <p class="auth-kicker">Welcome back</p>
    <h2>Login</h2>

    <form class="auth-form" action="/auth/login" method="POST">
      <div class="field-group">
        <label for="email">Email</label>
        <input type="email" name="email" id="email" autocomplete="email" required>
      </div>
      <div class="field-group">
        <label for="password">Password</label>
        <input type="password" name="password" id="password" autocomplete="current-password" required>
      </div>
      <button class="button" type="submit">Login</button>
    </form>

    <p class="auth-switch">Need a seat? <a href="/auth/register">Create an account</a></p>
  </section>
</section>

