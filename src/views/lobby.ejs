<%- include("partials/head", { title: "Lobby" }) %>
<%- include("partials/header", { user }) %>

<section class="lobby-hero" aria-labelledby="lobby-title">
  <div class="hero-copy">
    <p class="eyebrow">Online table</p>
    <h1 id="lobby-title">UNO Lobby</h1>
    <p>You are logged in as <strong><%= user.email %></strong>.</p>

    <button class="button create-game-button" id="create-game">Create Game</button>
  </div>

  <div class="uno-card-fan" aria-hidden="true">
    <span class="uno-card uno-card-red">7</span>
    <span class="uno-card uno-card-yellow">+2</span>
    <span class="uno-card uno-card-green">Skip</span>
    <span class="uno-card uno-card-blue">Reverse</span>
  </div>
</section>

<span id="current-user-id" data-user-id="<%= user.id %>" hidden></span>

<section class="games-panel" aria-labelledby="games-title">
  <div class="section-heading">
    <p class="eyebrow">Open matches</p>
    <h2 id="games-title">Choose a table</h2>
  </div>

  <div class="games-list" id="games-list"></div>
</section>

<template id="game-card-template">
  <div class="game-card">
    <span class="game-id" data-game-id></span>
    <span class="game-turn-badge" data-turn-badge></span>
    <span class="game-name" data-game-name></span>
    <span class="game-players" data-game-players></span>
    <button class="button button-small game-join-btn" data-join-btn>Join</button>
  </div>
</template>

<script defer src="/js/lobby.js"></script>

