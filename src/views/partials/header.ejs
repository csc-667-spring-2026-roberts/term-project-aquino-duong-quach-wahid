<nav class="top-bar">
  <a class="brand" href="/" aria-label="UNO home">
    <span class="brand-mark">UNO</span>
    <span class="brand-text">Game Room</span>
  </a>

  <div class="nav-actions">
    <% if (typeof user !== "undefined" && user) { %>
      <span class="signed-in">Signed in as <strong><%= user.email %></strong></span>
      <form action="/auth/logout" method="POST">
        <button class="button button-small button-outline" type="submit">Logout</button>
      </form>
    <% } else { %>
      <a class="nav-link" href="/auth/login">Login</a>
      <a class="button button-small" href="/auth/register">Register</a>
    <% } %>
  </div>
</nav>

<main class="page-shell">
  <% if (typeof error !== "undefined" && error) { %>
    <div class="error"><%= error %></div>
  <% } %>
